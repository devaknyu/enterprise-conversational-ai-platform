# =============================================================================
# Enterprise IT Support Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                    # development | staging | production
APP_NAME=enterprise-it-assistant
APP_VERSION=1.0.0
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-random-string-of-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
WEBHOOK_SHARED_SECRET=change-me-to-another-random-secret-16-chars-min

# -----------------------------------------------------------------------------
# LLM Backend — controls which model backend is used (and the cost)
#
# DEV (free):  LLM_BACKEND=gemini_api
#   → Uses google-generativeai package with a free AI Studio API key.
#   → Get a free key at https://aistudio.google.com (no billing account needed).
#   → Model: gemini-2.0-flash (free tier: 15 RPM, 1500 req/day, 1M tokens/day)
#
# PROD (paid): LLM_BACKEND=vertex_ai
#   → Uses vertexai package with GCP IAM auth (no API key needed on Cloud Run).
#   → Requires GOOGLE_CLOUD_PROJECT, GOOGLE_CLOUD_REGION, and a service account
#     with roles/aiplatform.user attached to the Cloud Run service.
# -----------------------------------------------------------------------------
LLM_BACKEND=gemini_api
GEMINI_API_KEY=                        # Required when LLM_BACKEND=gemini_api
GEMINI_MODEL=gemini-2.0-flash          # Free model; prod uses VERTEX_AI_MODEL

# -----------------------------------------------------------------------------
# Embedding Backend — controls which embedding model is used (and the cost)
#
# DEV (free):  EMBEDDING_BACKEND=local
#   → Uses sentence-transformers (all-MiniLM-L6-v2) running locally in-process.
#   → No API calls, no cost, no internet required for inference.
#   → First run downloads the model (~80MB) from HuggingFace.
#
# PROD (paid): EMBEDDING_BACKEND=vertex_ai
#   → Uses Vertex AI text-embedding-004 via google-cloud-aiplatform.
#   → Requires GCP credentials (see Google Cloud section below).
# -----------------------------------------------------------------------------
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_LOCAL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI (PRODUCTION ONLY)
# Not required when LLM_BACKEND=gemini_api and EMBEDDING_BACKEND=local
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=       # Path to service account JSON — LOCAL DEV ONLY
VERTEX_AI_MODEL=gemini-1.5-pro        # Used when LLM_BACKEND=vertex_ai

# -----------------------------------------------------------------------------
# ChromaDB
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./knowledge_base/chroma_db
CHROMA_COLLECTION_NAME=it_knowledge_base

# -----------------------------------------------------------------------------
# Integration Flags
# -----------------------------------------------------------------------------
USE_MOCK_INTEGRATIONS=true            # false in production
MOCK_ERROR_RATE=0.05                  # 5% random failure rate (mock realism)
MOCK_LATENCY_MS_MIN=100
MOCK_LATENCY_MS_MAX=300

# -----------------------------------------------------------------------------
# ServiceNow (used when USE_MOCK_INTEGRATIONS=false)
# -----------------------------------------------------------------------------
SERVICENOW_BASE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# -----------------------------------------------------------------------------
# Active Directory (used when USE_MOCK_INTEGRATIONS=false)
# -----------------------------------------------------------------------------
AD_BASE_URL=https://your-ad-api.internal
AD_SERVICE_ACCOUNT=

# -----------------------------------------------------------------------------
# VPN Gateway (used when USE_MOCK_INTEGRATIONS=false)
# -----------------------------------------------------------------------------
VPN_API_BASE_URL=https://your-vpn-api.internal
VPN_API_KEY=
